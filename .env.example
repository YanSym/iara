# ─────────────────────────────────────────────────────────────────────────────
# IAra Multi-Tenant Agent Runtime — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit a .env file with real secrets to version control.
# ─────────────────────────────────────────────────────────────────────────────

IARA_ENV=development
# Options: development | sandbox | staging | production

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://iara:iara_dev@localhost:5432/iara_dev
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# Message Queue (RabbitMQ)
RABBITMQ_URL=amqp://iara:iara_dev@localhost:5672/iara
RABBITMQ_PREFETCH_COUNT=5
RABBITMQ_RECONNECT_DELAY_SECONDS=5

# LLM provider ("openai" or "anthropic")
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=xxx
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=xxx
ANTHROPIC_MODEL=claude-sonnet-4-6
MAX_TOKENS=4096

# FastAPI / HTTP
IARA_HOST=0.0.0.0
IARA_PORT=8000
IARA_WORKERS=1
IARA_RELOAD=true
IARA_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
IARA_WEBHOOK_SECRET_REF=secret://iara/webhook_hmac_key

# Tenant resolution
IARA_TENANT_CACHE_TTL_SECONDS=60
IARA_TENANT_MAX_CACHE_SIZE=1000

# Chatwoot MCP
CHATWOOT_MCP_BASE_URL=http://localhost:3030
CHATWOOT_MCP_CREDENTIAL_REF=secret://chatwoot/mcp_token
CHATWOOT_MCP_TIMEOUT_SECONDS=30
CHATWOOT_MCP_MAX_RETRIES=3

# Google Calendar (optional)
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_CREDENTIAL_REF=secret://google/service_account_json

# Clinicorp (optional)
CLINICORP_ENABLED=false
CLINICORP_BASE_URL=https://api.clinicorp.com
CLINICORP_CREDENTIAL_REF=secret://clinicorp/api_key

# Debounce & lease
IARA_DEBOUNCE_SECONDS=3
IARA_LEASE_TTL_SECONDS=300
IARA_LEASE_REFRESH_INTERVAL_SECONDS=60

# Security
IARA_REDACT_SENSITIVE_FIELDS=true
IARA_AUDIT_LOG_LEVEL=INFO
IARA_OUTBOX_MAX_RETRIES=5
IARA_OUTBOX_RETRY_DELAY_SECONDS=30

# Media
IARA_MEDIA_MAX_SIZE_MB=50
IARA_AUDIO_TRANSCRIPTION_ENABLED=true
IARA_VISION_ENABLED=false
IARA_DOCUMENT_EXTRACTION_ENABLED=true

# Memory
IARA_MEMORY_ENABLED=false
IARA_MEMORY_TTL_DAYS=90
IARA_MEMORY_NAMESPACE=default

# Campaign & kanban defaults
IARA_KANBAN_DEFAULT_MODE=suggest_only
IARA_CAMPAIGN_DEFAULT_MODE=draft_only

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=console
# Options: json | console

# Production guard — MUST remain false without explicit authorization
IARA_PRODUCTION_AUTHORIZED=false
